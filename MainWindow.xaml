<Window x:Class="QrCodeGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR Code Generator" Height="760" Width="820"
        MinHeight="680" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#059669"/>
        </Style>
        <Style x:Key="NeutralButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <TabControl Margin="12" Background="Transparent" BorderThickness="0">

        <!-- ============ TAB 1: SINGLE ============ -->
        <TabItem Header="Single" Padding="14,8" FontWeight="SemiBold">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: scrollable controls -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="QR Code Generator" FontSize="22" FontWeight="Bold"
                                   Foreground="#111827" Margin="0,0,0,16"/>

                        <!-- URL builder (schema-driven) -->
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                CornerRadius="8" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Build URL from parameters" FontWeight="Bold"
                                               Foreground="#111827" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Load schema…"
                                            Style="{StaticResource NeutralButton}"
                                            Click="LoadSchemaButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="SchemaInfoText" Foreground="#6B7280"
                                           Margin="0,6,0,10" TextWrapping="Wrap"
                                           Text="No schema loaded."/>
                                <StackPanel x:Name="ParamsPanel"/>
                                <Button Content="Build URL ↓" Click="BuildUrlButton_Click"
                                        HorizontalAlignment="Left" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="URL / Text" Style="{StaticResource Label}"/>
                        <TextBox x:Name="UrlTextBox" Text="https://" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Error correction" Style="{StaticResource Label}"/>
                                <ComboBox x:Name="EccComboBox" Padding="8,6" SelectedIndex="2">
                                    <ComboBoxItem Content="L — Low (7%)"/>
                                    <ComboBoxItem Content="M — Medium (15%)"/>
                                    <ComboBoxItem Content="Q — Quartile (25%)"/>
                                    <ComboBoxItem Content="H — High (30%)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Pixels per module (PNG)" Style="{StaticResource Label}"/>
                                <TextBox x:Name="PixelsPerModuleTextBox" Text="20"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dark color (hex)" Style="{StaticResource Label}"/>
                                <TextBox x:Name="DarkColorTextBox" Text="#000000"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Light color (hex)" Style="{StaticResource Label}"/>
                                <TextBox x:Name="LightColorTextBox" Text="#FFFFFF"/>
                            </StackPanel>
                        </Grid>

                        <!-- Center graphic (optional) -->
                        <TextBlock Text="Center graphic (optional)" Style="{StaticResource Label}"/>
                        <ComboBox x:Name="CenterModeComboBox" Padding="8,6" SelectedIndex="0"
                                  Margin="0,0,0,10"
                                  SelectionChanged="CenterModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Image file (PNG / JPG)"/>
                            <ComboBoxItem Content="Font glyph (vector, TTF / OTF)"/>
                        </ComboBox>

                        <!-- Image sub-panel -->
                        <StackPanel x:Name="ImagePanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="LogoPathTextBox" Grid.Column="0" IsReadOnly="True"
                                         Background="#F3F4F6" Foreground="#6B7280"
                                         Text="No image selected"/>
                                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource NeutralButton}"
                                        Click="BrowseLogoButton_Click"/>
                                <Button Grid.Column="4" Content="Clear" Style="{StaticResource NeutralButton}"
                                        Click="ClearLogoButton_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Font glyph sub-panel -->
                        <StackPanel x:Name="FontPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FontPathTextBox" Grid.Column="0" IsReadOnly="True"
                                         Background="#F3F4F6" Foreground="#6B7280"
                                         Text="No font selected"/>
                                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource NeutralButton}"
                                        Click="BrowseFontButton_Click"/>
                                <Button Grid.Column="4" Content="Clear" Style="{StaticResource NeutralButton}"
                                        Click="ClearFontButton_Click"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Character(s)" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="FontCharsTextBox" Text=""/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Width="120">
                                    <TextBlock Text="Glyph color (hex)" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="GlyphColorTextBox" Text="#000000"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="SizePanel" Width="220" HorizontalAlignment="Left"
                                    Margin="0,0,0,4" Visibility="Collapsed">
                            <TextBlock Text="Graphic size (% of QR width)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="LogoSizeTextBox" Text="22"/>
                        </StackPanel>

                        <Button Content="Generate preview" Click="GenerateButton_Click"
                                HorizontalAlignment="Left" Margin="0,16,0,0"/>

                        <TextBlock x:Name="StatusText" Margin="0,18,0,0" TextWrapping="Wrap"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Right: preview + save actions -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="8"
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <Grid>
                            <TextBlock x:Name="PlaceholderText" Text="Preview"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#9CA3AF"/>
                            <Image x:Name="QrImage" Margin="20" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock Text="Save as" Style="{StaticResource Label}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SavePngButton" Content="Save .png"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SavePngButton_Click" IsEnabled="False"/>
                            <Button x:Name="SaveSvgButton" Content="Save .svg"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="SaveSvgButton_Click" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ============ TAB 2: BATCH ============ -->
        <TabItem Header="Batch → ZIP" Padding="14,8" FontWeight="SemiBold">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Batch → ZIP of SVGs" FontSize="22" FontWeight="Bold"
                           Foreground="#111827" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,0,0,12"
                    Text="Paste one URL per line. Each URL becomes a QR .svg inside a single ZIP. Filenames are built from the URL with the protocol and subdomain removed; every character that isn't a–z or 0–9 (path and querystring included) becomes an underscore. Colors and error-correction from the Single tab are reused."/>

                <TextBox Grid.Row="2" x:Name="BatchUrlsTextBox"
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top" FontFamily="Consolas" Padding="8"
                         MinHeight="240"/>

                <Button Grid.Row="3" Content="Generate ZIP…" Click="GenerateZipButton_Click"
                        HorizontalAlignment="Left" Margin="0,14,0,0"/>

                <TextBlock Grid.Row="4" x:Name="BatchStatusText" Margin="0,14,0,0"
                           TextWrapping="Wrap" Foreground="#6B7280"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
